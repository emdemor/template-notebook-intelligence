FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN pip install --upgrade pip && \
    pip install "jupyterlab>=4.5" notebook-intelligence

RUN mkdir -p /root/.jupyter/nbi && \
    echo '{"claude_settings":{"enabled":true,"tools":["claude-code:built-in-tools","nbi:built-in-jupyter-ui-tools"],"setting_sources":["user","project"]}}' \
    > /root/.jupyter/nbi/config.json

RUN mkdir -p /root/.claude

EXPOSE 8888

CMD ["jupyter", "lab", \
     "--ip=0.0.0.0", \
     "--port=8888", \
     "--no-browser", \
     "--allow-root", \
     "--NotebookApp.token=''", \
     "--NotebookApp.password=''"]
